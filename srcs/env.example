# Ming frontend environment example (trackable)

# IPFS
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_KEY=your_pinata_secret_key

# Wallet postMessage security
# External wallet page (AnDaoWallet) URL; if empty, fallback to same-window integration
VITE_WALLET_APP_URL=http://localhost:5173
# andao | metamask (empty means auto: use andao if VITE_WALLET_APP_URL is set)
VITE_WALLET_CONNECTION_MODE=andao
VITE_WALLET_WINDOW_NAME=AnDaoWalletBridge
VITE_WALLET_TARGET_ORIGIN=http://localhost:5173
VITE_WALLET_ALLOWED_ORIGINS=http://localhost:5173
# Optional: wallet bridge debug logs (true/false)
VITE_WALLET_BRIDGE_DEBUG=false

# Chain settings
# evm | solana
VITE_CHAIN_FAMILY=solana
# e.g. sepolia / solana-devnet
VITE_CHAIN_NETWORK=solana-devnet
# Optional for EVM-only mode when MetaMask network is unavailable
VITE_CHAIN_ID=43114

# EVM: 0x...
# Solana: Program ID (base58)
VITE_NFT_CONTRACT_ADDRESS=5Ga3kk79rpPJy5joLvZKoJowRsEGvfcMpSDqAahYEVKT

# AI命理学习（前端 -> Vercel API）
VITE_AI_CHAT_API_PATH=/api/fortune-chat
VITE_AI_FORTUNE_MODEL=Qwen/Qwen3-8B

# 服务端变量（配置在Vercel项目环境变量中，不要放到前端.env）
# MODELSCOPE_API_KEY=your_modelscope_api_key
# AI_FORTUNE_MODEL=Qwen/Qwen3-8B
# AI_FORTUNE_FALLBACK_MODEL=Qwen/Qwen3-8B
# AI_FORTUNE_BASE_URL=https://api-inference.modelscope.cn/v1
# AI_FORTUNE_API_URL=https://api-inference.modelscope.cn/v1/chat/completions
# AI_FORTUNE_ALLOWED_MODELS=Qwen/Qwen3-8B,dclef233/BaZi-Qwen3-1.7B-GGUF
# AI_FORTUNE_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# AI_FORTUNE_RATE_LIMIT=20
# AI_FORTUNE_MAX_MESSAGES=30
# AI_FORTUNE_MAX_CONTENT_CHARS=4000
# AI_FORTUNE_MAX_HISTORY_TURNS=20
# AI_FORTUNE_QA_MODEL=Qwen/Qwen3-8B
# AI_FORTUNE_QA_MAX_TOKENS=420
# AI_FORTUNE_FULL_MAX_TOKENS=900
# AI_FORTUNE_CACHE_TTL_MS=120000
# AI_FORTUNE_CACHE_MAX_SIZE=200
# AI_FORTUNE_TIMEOUT_MS=90000
# AI_FORTUNE_LOCAL_CONTEXT_MAX_CHARS=1200
# AI_FORTUNE_ENABLE_AUTOCORRECT=true
# AI_FORTUNE_SYSTEM_PROMPT=（可覆盖默认“命理学习顾问”提示词）
# AI_FORTUNE_CLIENT_TOKEN=optional_shared_token
